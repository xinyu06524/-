#include <iostream>
#include <iomanip>
#include <cmath>
using namespace std;

int main(){
    int n;
    cin >> n;
    while(n--){
        double s;
        cin >> fixed >> setprecision(1) >> s;
        double area=s*s;
		area = floor(area * 10 + 0.5) / 10;		//小數點後第一位大於5進位
        cout << fixed << setprecision(1) << area << endl;
    }
	return 0;
}
