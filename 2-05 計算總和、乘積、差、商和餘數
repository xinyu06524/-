#include <stdio.h>
#include <stdlib.h>
int main(){
    int a, b;
    scanf("%d %d", &a, &b);
    printf("%d+%d=%d\n", a, b, a+b);
    printf("%d*%d=%d\n", a, b, a*b);
    printf("%d-%d=%d\n", a, b, a-b);
    if(a<0)printf("%d/%d=%d...%d\n", a, b, a/b-1, a%b+b);	//-20/8=-3...4
    else printf("%d/%d=%d...%d\n", a, b, a/b, a%b);
	return 0;
}
