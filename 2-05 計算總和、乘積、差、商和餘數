#include <iostream>
using namespace std;

int main(){
    int a, b;
    cin >> a >> b;
    cout << a << "+" << b << "=" << a+b << endl;
    cout << a << "*" << b << "=" << a*b << endl;
    cout << a << "-" << b << "=" << a-b << endl;
    if(a<0) cout << a << "/" << b << "=" << a/b-1 << "..." << a%b+b << endl;	//-20/8=-3...4
    else cout << a << "/" << b << "=" << a/b << "..." << a%b << endl;
	return 0;
}
