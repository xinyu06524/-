#include <stdio.h>
#include <stdlib.h>
int main(){
    int hr, money;
    scanf("%d %d", &hr, &money);
    double total;
    if(hr<=60)total=hr*money;	//前60小時固定時薪
    else if(60<hr&&hr<=120)total=60*money+(hr-60)*money*1.33;	//第61-120小時固定時薪*1.33
    else total=60*money+60*money*1.33+(hr-120)*money*1.66;		//121小時後固定時薪*1.66
    printf("%.1lf", total);
	return 0;
}
